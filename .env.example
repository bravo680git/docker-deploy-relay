# Required environment variables
RELAY_WEBHOOK_API_KEY=your-secure-api-key
RELAY_DOCKER_HUB_USER=your-docker-hub-username
RELAY_DOCKER_HUB_PASS=your-docker-hub-password

# Optional settings
RELAY_PROJECT_ROOT=/apps

# Optional safety limits
# RELAY_MAX_CONCURRENT_DEPLOYS=2
# RELAY_DEPLOY_TIMEOUT=15m
# RELAY_DOCKER_PULL_TIMEOUT=10m
# RELAY_DOCKER_COMPOSE_TIMEOUT=10m
# RELAY_HUB_TIMEOUT=20s
# RELAY_HUB_HTTP_TIMEOUT=10s
# RELAY_RATE_LIMIT_RPS=1
# RELAY_RATE_LIMIT_BURST=5
